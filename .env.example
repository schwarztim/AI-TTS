# ara-tts configuration
# Copy this file to ~/.config/ara-tts/.env and edit as needed.
# All settings are optional — defaults shown below.

# Voice to use (run `ara-tts voice list` to see all 22 options)
TTS_VOICE=af_heart

# Server port
TTS_PORT=5111

# When to play TTS: "on-complete" (after full response) or "immediate" (before first tool call)
# TTS_TIMING=on-complete

# Override the server URL for hook scripts (useful if running on a different host/port)
# ARA_TTS_SERVER=http://127.0.0.1:5111

# Speech speed multiplier (default: 1.1)
# TTS_SPEED=1.1

# Alert cache directory (pre-generated audio cues)
# ALERT_CACHE_DIR=~/.config/ara-tts/alert_cache

# Enable WAV debug dumps to ~/Desktop/tts_debug/
# TTS_DEBUG_DUMP=0
